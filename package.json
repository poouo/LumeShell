{
  "name": "lumeshell",
  "version": "0.1.0",
  "description": "A modern personal WebSSH console with encrypted credentials, SFTP file management, quick commands, and built-in upgrades.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "check": "node server/scripts/doctor.js"
  },
  "keywords": [
    "webssh",
    "ssh",
    "sftp",
    "terminal",
    "self-hosted"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "archiver": "^7.0.1",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.17.0",
    "vite": "^7.0.0",
    "ws": "^8.18.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
